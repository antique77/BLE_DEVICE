{
    // ========== CMake 配置 ==========
    "cmake.sourceDirectory": "${workspaceFolder}/cmake_gcc",
    "cmake.buildDirectory": "${workspaceFolder}/cmake_gcc/build",

    // ========== 禁用 VS Code 内置 IntelliSense（使用clangd替代）==========
    "C_Cpp.intelliSenseEngine": "disabled",
    "C_Cpp.automaticAddFileAssociations": false,
    "C_Cpp.errorSquiggles": "disabled",
    "C_Cpp.codeAnalysis.runAutomatically": false,

    // ========== Clangd 语言服务器配置 ==========
    "clangd.path": "/usr/bin/clangd",
    "clangd.arguments": [
        "--background-index",
        "--completion-style=detailed",
        "-j=4",
        "--header-insertion=iwyu",
        "--pch-storage=disk",
        "--all-scopes-completion",
        "--enable-config",
        // 关键：让clangd识别arm交叉编译工具链
        "--query-driver=/home/ty/.silabs/slt/installs/conan/p/gcc-a442105b5c2637/p/bin/arm-none-eabi-gcc,**/bin/arm-none-eabi-*",
        "--limit-results=500"
    ],

    // ========== 文件关联 ==========
    "[c]": {
        "editor.defaultFormatter": null,
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "files.associations": {
        "*.h": "c",
        "*.c": "c"
    },

    // ========== 排除无关文件 ==========
    "files.exclude": {
        "**/.git": true,
        "cmake_gcc/build/**": true,
        "**/*.o": true,
        "**/*.obj": true,
        "**/*.a": true
    }
}
